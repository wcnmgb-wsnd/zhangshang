// ==================== 主循环 ====================
void loop() {
  unsigned long now = micros();
  float dt = (now - last_time) / 1000000.0;
  
  if (dt > 0.1) dt = DT;
  if (dt <= 0) dt = DT;
  
  last_time = now;
  
  readRawData();
  processData();
  updateAttitude(dt);
  
  loop_count++;
  if (loop_count % 2 == 0) {
    printData();
  }
  
  int delay_time = (int)(DT * 1000) - 2;
  if (delay_time > 0) {
    delay(delay_time);
  }
}

// ==================== 额外工具函数 ====================

float getYaw() { return yaw; }
float getRoll() { return roll; }
float getPitch() { return pitch; }

void getAccel(float &x, float &y, float &z) {
  x = accelX_f;
  y = accelY_f;
  z = accelZ_f;
}

void getGyro(float &x, float &y, float &z) {
  x = gyroX_f;
  y = gyroY_f;
  z = gyroZ_f;
}

void resetYaw() {
  yaw = 0;
  roll_gyro = roll;
  pitch_gyro = pitch;
  gyro_bias_z_dynamic = 0;  // 重置动态零偏
}

void resetAngles() {
  roll = 0;
  pitch = 0;
  yaw = 0;
  roll_gyro = 0;
  pitch_gyro = 0;
  gyro_bias_z_dynamic = 0;
}

String getStatus() {
  float accel_mag = sqrt(accelX_f*accelX_f + accelY_f*accelY_f + accelZ_f*accelZ_f);
  if (fabs(accel_mag - 1.0) < 0.05) {
    return "NORMAL";
  } else if (fabs(accel_mag - 1.0) < 0.2) {
    return "WARNING";
  } else {
    return "ERROR";
  }
}

